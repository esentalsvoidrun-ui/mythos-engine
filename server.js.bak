import path from 'path';
import { fileURLToPath } from 'url';
import express from "express";
import { WebSocketServer } from "ws";
import path from "path";
import { fileURLToPath } from "url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const app = express();
const PORT = 3000;

app.use(express.static(path.join(__dirname, "public")));

app.get("/dashboard", (req, res) => {
  res.sendFile(path.join(__dirname, "public", "index.html"));
});

const server = app.listen(PORT, () => {
  console.log(`🚀 Dashboard live at http://localhost:${PORT}/dashboard`);
});

const wss = new WebSocketServer({ server });
wss.on("connection", ws => {
  console.log("New WebSocket connection");
  const interval = setInterval(() => {
    const ev = {
      time: new Date().toLocaleTimeString(),
      type: ["good","warn","critical"][Math.floor(Math.random()*3)],
      newUsers: Math.floor(Math.random()*10),
      newRevenue: Math.floor(Math.random()*1000),
      churn: Math.floor(Math.random()*5),
      newErrors: Math.floor(Math.random()*3)
    };
    ws.send(JSON.stringify(ev));
  }, 2000);

  ws.on("close", () => clearInterval(interval));
});
app.use('/demo', express.static(path.join(__dirname, 'public_offline')));
